# Variables de entorno para GobIA Auditor
API_KEY_SECOP=
SECOP_APP_TOKEN=
LLM_API_KEY=
LLM_PROVIDER=OpenAI
LLM_MODEL=gpt-3.5-turbo
SECOP_API_URL=https://www.datos.gov.co/resource/rtxx-3nky.json
SECOP_DAYS_WINDOW=30
SECOP_MAX_RECORDS=200
SECOP_USE_SAMPLE_DATA=false
RISK_THRESHOLD=70

# Correo electrónico para enviar el reporte
SMTP_HOST=smtp.tu_proveedor.com
SMTP_PORT=587
SMTP_USER=tu_email@ejemplo.com
SMTP_PASSWORD=tu_contraseña_segura
EMAIL_FROM=tu_email@ejemplo.com
EMAIL_TO=destinatario@ejemplo.com
